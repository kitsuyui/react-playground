{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2020",
    "lib": ["esnext", "dom"],
    "types": ["react"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "**/__screenshots__/**",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/stories/**",
    "node_modules"
  ]
}
