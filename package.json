{
  "name": "react-playground",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "config/*",
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --sequential --workspaces build",
    "check-module-isolation": "find packages -type d -name src -print -exec bunx ts-module-isolation -- {} +",
    "dev": "bun run --parallel --workspaces dev",
    "format": "bun run format:biome && bun run format:package-json",
    "format:biome": "biome lint --write ./",
    "format:package-json": "sort-package-json \"package.json\" \"packages/*/package.json\"",
    "lint": "bun run lint:biome && bun run lint:package-json",
    "lint:biome": "biome lint ./",
    "lint:package-json": "sort-package-json --check \"package.json\" \"packages/*/package.json\"",
    "start": "bun run --parallel --workspaces dev",
    "test": "vitest run --coverage packages/*/src",
    "test:browser": "vitest run --config vitest.browser.config.mts",
    "test:browser:docker": "./scripts/test-browser-docker.sh",
    "test:browser:install": "playwright install chromium",
    "test:browser:update": "vitest run --config vitest.browser.config.mts --update",
    "test:coverage:browser": "vitest run --config vitest.browser.config.mts --coverage.enabled --coverage.reporter=clover --coverage.reporter=text --coverage.reportsDirectory=coverage/browser",
    "test:coverage:browser:docker": "./scripts/test-browser-docker.sh --coverage.enabled --coverage.reporter=clover --coverage.reporter=text --coverage.reportsDirectory=coverage/browser",
    "test:coverage:unit": "vitest run --coverage packages/*/src --coverage.reporter=clover --coverage.reporter=text --coverage.reportsDirectory=coverage/unit",
    "typecheck": "tsc --noEmit packages/*/src/**/*.ts --skipLibCheck --jsx react-jsx",
    "typedoc": "typedoc",
    "typedoc:server": "serve -p 8000 build/typedocs",
    "validate": "bun run --workspaces --if-present validate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "^28.1.0",
    "playwright": "1.58.1",
    "rollup": "^4.52.5",
    "serve": "^14.2.5",
    "sort-package-json": "^3.6.1",
    "ts-module-isolation": "^1.0.2",
    "tsdown": "^0.20.3",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "validate-package-exports": "^0.18.0",
    "vite": "7.3.2",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "4.0.18",
    "vitest-browser-react": "2.0.5"
  },
  "packageManager": "bun@1.3.11"
}
